# TokmeterBar — release credentials
#
# Copy to .env (which is gitignored) and fill in real values.
# Source it before running ./bundle.sh --release:
#   set -a; source .env; set +a
#   ./bundle.sh --release

# ─── Required for --signed and --release ───────────────────────────────
# Find your identity:
#   security find-identity -v -p codesigning | grep "Developer ID Application"
DEV_ID="Developer ID Application: Your Name (XXXXXXXXXX)"

# ─── Required for --release (notarization) ─────────────────────────────
# Your Apple ID email
APPLE_ID="you@example.com"

# Your 10-character Team ID — find at https://developer.apple.com/account
APPLE_TEAM_ID="XXXXXXXXXX"

# App-specific password — generate at https://appleid.apple.com under
# "App-Specific Passwords." Do NOT use your real Apple ID password.
APPLE_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# ─── Required for --release (Sparkle update signing) ───────────────────
# Path to the ed25519 private key generated by ./generate-sparkle-keys.sh
SPARKLE_PRIVATE_KEY_PATH="./sparkle_ed25519_priv"

# Public URL where the release zip will be hosted (e.g. GitHub Releases).
# This URL goes into the appcast.xml enclosure tag.
# Use {VERSION} as a placeholder — bundle.sh substitutes it with $SHORT_VERSION
# so you never have to remember to update this when bumping versions.
RELEASE_DOWNLOAD_URL="https://github.com/sriinnu/tokmeter/releases/download/v{VERSION}/TokmeterBar-{VERSION}.zip"

# ─── Optional ──────────────────────────────────────────────────────────
# Override the appcast feed URL embedded in Info.plist
# SUFEED_URL="https://raw.githubusercontent.com/sriinnu/tokmeter/main/packages/macos-bar/appcast.xml"

# Override version (defaults: 0.1.0 / 1)
# CFBundleShortVersionString="0.2.0"
# CFBundleVersion="2"
