{
  "name": "@sriinnu/drishti",
  "version": "1.9.0",
  "description": "दृष्टि — MCP server + live token observatory for AI coding agents",
  "type": "module",
  "bin": {
    "drishti": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./live.js": {
      "types": "./dist/live.d.ts",
      "import": "./dist/live.js"
    },
    "./statusline.js": {
      "types": "./dist/statusline.d.ts",
      "import": "./dist/statusline.js"
    },
    "./daemon/server.js": {
      "types": "./dist/daemon/server.d.ts",
      "import": "./dist/daemon/server.js"
    },
    "./installer.js": {
      "types": "./dist/installer.d.ts",
      "import": "./dist/installer.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "bun src/cli.ts",
    "serve": "bun src/cli.ts serve",
    "live": "bun src/cli.ts live",
    "statusline": "bun src/cli.ts statusline"
  },
  "dependencies": {
    "@sriinnu/tokmeter": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0",
    "chalk": "^5.3.0",
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.0"
  },
  "license": "AGPL-3.0-only",
  "author": "Srinivas Pendela <sriinnu@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sriinnu/tokmeter.git",
    "directory": "packages/mcp"
  },
  "keywords": [
    "tokens",
    "ai",
    "llm",
    "usage-tracking",
    "pricing",
    "mcp",
    "claude",
    "anthropic",
    "statusline"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
