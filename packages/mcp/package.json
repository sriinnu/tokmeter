{
  "name": "@tokmeter/drishti",
  "version": "0.1.0",
  "description": "दृष्टि — MCP server + live token observatory for AI coding agents",
  "type": "module",
  "bin": {
    "drishti": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "bun src/cli.ts",
    "serve": "bun src/cli.ts serve",
    "live": "bun src/cli.ts live",
    "statusline": "bun src/cli.ts statusline"
  },
  "dependencies": {
    "@tokmeter/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0",
    "chalk": "^5.3.0",
    "ink": "^5.0.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "author": "Srinivas Pendela <sriinnu@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/sriinnu/tokmeter.git",
    "directory": "packages/mcp"
  },
  "keywords": [
    "tokens",
    "ai",
    "llm",
    "usage-tracking",
    "pricing",
    "mcp",
    "claude",
    "anthropic",
    "statusline"
  ],
  "engines": { "node": ">=22.0.0" },
